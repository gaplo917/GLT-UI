{
  "name": "glt-ui",
  "version": "0.1.0",
  "description": "GLT UI — production React components with SCSS brand theme tokens (Atomic Design)",
  "license": "MIT",
  "author": "Gary Lo <logap@me.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaplo917/GLT-UI.git",
    "directory": "packages/glt-ui"
  },
  "homepage": "https://gaplo917.github.io/GLT-UI/",
  "bugs": {
    "url": "https://github.com/gaplo917/GLT-UI/issues"
  },
  "keywords": [
    "react",
    "ui",
    "design-system",
    "components",
    "tailwind",
    "scss",
    "atomic-design",
    "glt"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.scss",
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./theme/css-vars": "./theme/scss/_css-vars.scss",
    "./theme/components": "./theme/scss/_components.scss",
    "./theme/styles": "./theme/styles.scss",
    "./theme/variables": "./theme/scss/_variables.scss",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "theme",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "clsx": "^2",
    "shiki": "^1.29.2",
    "tailwind-merge": "^2"
  },
  "devDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  }
}
