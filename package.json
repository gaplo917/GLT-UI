{
  "name": "glt-ui",
  "version": "0.3.0",
  "description": "GLT UI — production React components with SCSS brand theme tokens (Atomic Design)",
  "license": "MIT",
  "author": "Gary Lo <logap@me.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaplo917/GLT-UI.git"
  },
  "homepage": "https://gaplo917.github.io/GLT-UI/",
  "bugs": {
    "url": "https://github.com/gaplo917/GLT-UI/issues"
  },
  "keywords": [
    "react",
    "ui",
    "design-system",
    "components",
    "tailwind",
    "scss",
    "atomic-design",
    "glt"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.scss",
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./theme/css-vars": "./theme/scss/_css-vars.scss",
    "./theme/components": "./theme/scss/_components.scss",
    "./theme/styles": "./theme/styles.scss",
    "./theme/variables": "./theme/scss/_variables.scss",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "theme",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "demo"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "build:watch": "concurrently -k -n tsc,alias -c blue,yellow \"tsc -p tsconfig.build.json -w --preserveWatchOutput\" \"tsc-alias -p tsconfig.build.json -w\"",
    "prepublishOnly": "npm run build",
    "predev": "npm run build",
    "dev": "npm run dev -w demo",
    "build:demo": "npm run build && npm run build -w demo",
    "build:pages": "npm run build && npm run build:pages -w demo",
    "start": "npm run start -w demo",
    "lint": "npm run lint -w demo",
    "publish:ui": "npm publish --access public"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "clsx": "^2",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.4",
    "tsc-alias": "^1.9.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "allowScripts": {
    "unrs-resolver@1.12.2": true,
    "sharp@0.34.5": true,
    "@parcel/watcher@2.5.6": true
  }
}
